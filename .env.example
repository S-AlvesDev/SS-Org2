# Variáveis para conexão com supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Segredos
JWT_SECRET=super_secret_for_development

# Configurações de E-mail (SMTP)
# Se estas variáveis não forem configuradas, o sistema usará o Ethereal Email em ambiente de desenvolvimento.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-gmail
SMTP_FROM_EMAIL=nao-responda@ssimoveis.com
